# setlist-maker 백엔드 환경변수 (예시)
# 이 파일을 복사해 `src/backend/.env` 를 만들고 값을 채우세요.
# .env 는 .gitignore 로 커밋 차단됩니다. 실제 키를 이 예시 파일에 적지 마세요.

# ── OpenRouter (필수: 실제 LLM 경로) ────────────────────────────────
# 키가 있으면 백엔드가 OpenRouter 어댑터를 자동 사용(없으면 stub 오프라인).
OPENROUTER_API_KEY=

# 모델 ID (미설정 시 nvidia/nemotron-3-nano-30b-a3b:free — 무료 기본).
# 유료 대안 예: openai/gpt-4o-mini, google/gemini-flash-1.5, anthropic/claude-3.5-haiku
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# 응답 포맷 강제: none(기본·전 모델 호환) | json_object | json_schema
#   - OpenAI/Google 계열은 json_schema 로 두면 더 안정적.
#   - Anthropic 계열은 none 권장(json_schema 미지원).
OPENROUTER_RESPONSE_FORMAT=none

# 해석기 강제 선택(선택): stub | openrouter  (미설정 시 키 유무로 자동 판단)
# MOOD_INTERPRETER=openrouter

# ── CORS / 배포 ─────────────────────────────────────────────────────
# 프론트 배포 오리진(쉼표 구분). 개발용 localhost 는 항상 허용됨.
# FRONTEND_ORIGIN=https://sbb2002.github.io

# ── 데이터 (선택) ───────────────────────────────────────────────────
# 기본: 배포된 backend는 런타임에 `data` 브랜치의 songs_master.csv를 원격 fetch한다
# (main엔 data/가 없음 — app.repo.remote_source). 로컬 개발 시 이 값을 설정하면 원격 fetch를
# 건너뛰고 로컬 파일을 바로 쓴다(예: 형제 data 브랜치 워크트리 경로).
# SONGS_CSV=

# `data` 브랜치 재fetch 주기(초). 기본 1800(30분), 0=비활성(기동 시 1회만 로드).
# DATA_REFRESH_INTERVAL_SEC=1800
